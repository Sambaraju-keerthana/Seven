📍 7️⃣ pwd — Print working directory
pwd
pwd -P
echo $(pwd)
cd /tmp && pwd
mkdir test && cd test && pwd
pwd | wc -c
pwd > path.txt
echo "Current path: $(pwd)"
🔝 8️⃣ head — Show beginning of file
head file.txt
head -n 5 file.txt
head -n 20 file.txt
head -c 50 file.txt
head *.txt
head -q file1.txt file2.txt
head /etc/passwd
head file.txt | grep hello
head -v file.txt
head -n -5 file.txt
🔚 9️⃣ tail — Show end of file
tail file.txt
tail -n 5 file.txt
tail -f logfile.txt
tail -c 50 file.txt
tail -n 20 file.txt
tail *.txt
tail -v file.txt
tail -f /var/log/syslog
tail -n +5 file.txt
tail file.txt | grep error
